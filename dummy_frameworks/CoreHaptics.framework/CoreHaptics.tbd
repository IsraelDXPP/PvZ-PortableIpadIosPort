--- !tapi-tbd-v3
archs:           [ armv7, armv7s, arm64, arm64e ]
platform:        ios
install-name:    /System/Library/Frameworks/CoreHaptics.framework/CoreHaptics
objc-constraint: none
exports:         
  - archs:           [ armv7, armv7s, arm64, arm64e ]
    symbols:         [ _CHHapticDynamicParameterIDAudioAttackTime, _CHHapticDynamicParameterIDAudioBrightnessControl, _CHHapticDynamicParameterIDAudioPan, _CHHapticDynamicParameterIDAudioPitchControl, _CHHapticDynamicParameterIDAudioReleaseTime, _CHHapticDynamicParameterIDAudioVolumeControl, _CHHapticDynamicParameterIDHapticAttackTime, _CHHapticDynamicParameterIDHapticIntensityControl, _CHHapticDynamicParameterIDHapticReleaseTime, _CHHapticDynamicParameterIDHapticSharpnessControl, _CHHapticEventParameterIDAudioAttackTime, _CHHapticEventParameterIDAudioBrightnessControl, _CHHapticEventParameterIDAudioPan, _CHHapticEventParameterIDAudioPitchControl, _CHHapticEventParameterIDAudioReleaseTime, _CHHapticEventParameterIDAudioVolumeControl, _CHHapticEventParameterIDHapticAttackTime, _CHHapticEventParameterIDHapticIntensityControl, _CHHapticEventParameterIDHapticReleaseTime, _CHHapticEventParameterIDHapticSharpnessControl, _CHHapticEventTypeAudioClick, _CHHapticEventTypeAudioContinuous, _CHHapticEventTypeAudioCustom, _CHHapticEventTypeHapticContinuous, _CHHapticEventTypeHapticTransient, _CHHapticPatternKeyConfiguration, _CHHapticPatternKeyEvents, _CHHapticPatternKeyParameterCurves, _CHHapticPatternKeyParameters, _CHHapticPatternKeyVersion ]
    objc-classes:    [ CHHapticDynamicParameter, CHHapticEngine, CHHapticEvent, CHHapticEventParameter, CHHapticParameterCurve, CHHapticParameterCurveControlPoint, CHHapticPattern ]
...
